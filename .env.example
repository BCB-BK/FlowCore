# Database
DATABASE_URL=postgresql://user:password@localhost:5432/flowcore

# API Server
LOG_LEVEL=info
API_PORT=3001
SESSION_SECRET=change-me-to-a-random-string

# Microsoft Entra ID (SSO)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=
# Optional: restrict login to members of this Entra group (BildungsCampus - Übergreifend).
# Leave empty to allow all users in the tenant.
ENTRA_REQUIRED_GROUP_ID=

# Microsoft Teams
TEAMS_APP_ID=

# Auth
AUTH_DEV_MODE=true

# AI / OpenAI
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# App
APP_PUBLIC_URL=
